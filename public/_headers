# Cloudflare Pages header rules.
#
# Force the correct MIME on the PWA web app manifest — some browsers reject
# the install prompt when Content-Type isn't application/manifest+json.
/manifest.webmanifest
  Content-Type: application/manifest+json

# Long-cache Vite's hashed asset bundles.
/assets/*
  cache-control: max-age=31536000
  cache-control: immutable
