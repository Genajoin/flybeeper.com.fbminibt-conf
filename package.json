{
  "type": "module",
  "private": true,
  "packageManager": "pnpm@8.13.1",
  "scripts": {
    "build": "vite-ssg build",
    "dev-local": "vite --port 3333 --open",
    "dev": "vite --port 5173 --host",
    "lint": "eslint .",
    "preview": "vite preview --port 5173 --host",
    "preview-https": "serve dist --port 5173 --host",
    "test": "vitest",
    "test:e2e": "cypress open",
    "test:unit": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "up": "taze major -I",
    "postinstall": "npx simple-git-hooks",
    "sizecheck": "npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@unhead/vue": "^1.10.0",
    "@unocss/reset": "^0.58.9",
    "@vueuse/core": "^10.11.1",
    "@vueuse/head": "^2.0.0",
    "lodash.clonedeep": "^4.5.0",
    "loglevel": "^1.9.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.2.2",
    "vue": "^3.4.38",
    "vue-3d-loader": "^2.2.4",
    "vue-demi": "^0.14.10",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.26.0",
    "@iconify-json/carbon": "^1.1.37",
    "@iconify/json": "^2.2.239",
    "@intlify/unplugin-vue-i18n": "^2.0.0",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/nprogress": "^0.2.3",
    "@types/web-bluetooth": "^0.0.20",
    "@unocss/eslint-config": "^0.58.9",
    "@vitejs/plugin-vue": "^5.1.2",
    "@vue-macros/volar": "^0.18.18",
    "@vue/test-utils": "^2.4.6",
    "critters": "^0.0.20",
    "cross-env": "^7.0.3",
    "cypress": "^13.13.3",
    "cypress-vite": "^1.5.0",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^2.15.2",
    "eslint-plugin-format": "^0.1.2",
    "https-localhost": "^4.7.1",
    "lint-staged": "^15.2.9",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-shikiji": "^0.9.19",
    "pnpm": "^8.15.9",
    "rollup": "^4.21.0",
    "shikiji": "^0.9.19",
    "simple-git-hooks": "^2.11.1",
    "taze": "^0.13.9",
    "typescript": "^5.5.4",
    "unocss": "^0.58.9",
    "unplugin-auto-import": "^0.17.8",
    "unplugin-vue-components": "^0.26.0",
    "unplugin-vue-macros": "^2.11.6",
    "unplugin-vue-markdown": "^0.25.2",
    "unplugin-vue-router": "^0.7.0",
    "vite": "^5.4.2",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-inspect": "^0.8.6",
    "vite-plugin-pwa": "^0.17.5",
    "vite-plugin-vue-devtools": "1.0.0-rc.8",
    "vite-plugin-vue-layouts": "^0.10.0",
    "vite-plugin-webfont-dl": "^3.9.5",
    "vite-ssg": "^0.23.8",
    "vite-ssg-sitemap": "^0.6.1",
    "vitest": "^1.6.0",
    "vue-tsc": "^1.8.27"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
